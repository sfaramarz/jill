ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Jira Server / Data Center
# PAT-only (Bearer auth): set JIRA_API_TOKEN, leave JIRA_USERNAME blank
# Basic Auth: set both JIRA_USERNAME and JIRA_API_TOKEN
JIRA_BASE_URL=https://jirasw.nvidia.com
JIRA_USERNAME=your_ldap_username
JIRA_API_TOKEN=your_personal_access_token

# Confluence Server / Data Center
CONFLUENCE_BASE_URL=https://confluence.nvidia.com
CONFLUENCE_USERNAME=your_ldap_username
CONFLUENCE_API_TOKEN=your_personal_access_token

OBSIDIAN_VAULT_PATH=C:\Users\sfaramarz\path\to\your\vault

# Pinned Obsidian notes — always injected into every Jill prompt regardless of query.
# Separate multiple entries with semicolons. Accepts vault-relative paths or obsidian:// URLs.
# Example: obsidian://open?vault=Obsidian&file=General%20Knowledge%2FTPM%20Producer%20Resources
OBSIDIAN_PINNED_NOTES=

# GitHub (optional) — leave blank to disable GitHub connector
# GITHUB_TOKEN:    Personal Access Token with repo/read:org scopes
# GITHUB_USERNAME: Your GitHub login (e.g. sfaramarz)
# GITHUB_ORG:      GitHub org to scope searches (optional)
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_ORG=

# GitLab (optional) — leave blank to disable GitLab connector
# GITLAB_BASE_URL: Your GitLab instance URL (e.g. https://gitlab-master.nvidia.com)
# GITLAB_TOKEN:    Personal Access Token with api scope
GITLAB_BASE_URL=
GITLAB_TOKEN=

# Slack (optional) — leave blank to disable Slack connector
# SLACK_TOKEN: User token (xoxp-...) gives full access including search & DMs [recommended]
#              Bot token (xoxb-...) gives channel history only (bot must be invited to channels)
# Required user token scopes: channels:history, channels:read, groups:history, groups:read,
#   im:history, im:read, mpim:history, mpim:read, search:read, users:read
# SLACK_CHANNEL_IDS: Comma-separated list of channel IDs to include in briefings (optional).
#   If blank, Jill will auto-discover your most recent joined channels.
SLACK_TOKEN=
SLACK_CHANNEL_IDS=
